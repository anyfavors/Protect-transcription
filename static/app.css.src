@tailwind base;
@tailwind components;
@tailwind utilities;

[x-cloak] { display: none !important; }

.audio-player { max-width: 100%; height: 32px; }

mark { background-color: #fef08a; padding: 0 2px; border-radius: 2px; }
.dark mark { background-color: #854d0e; color: #fef9c3; }

[id^="segments-"] { max-height: 280px; overflow-y: auto; scroll-behavior: smooth; }

@keyframes segment-pulse {
    0%, 100% { background-color: rgb(219 234 254); }
    50%       { background-color: rgb(191 219 254); }
}
@keyframes segment-pulse-dark {
    0%, 100% { background-color: rgb(30 58 138 / 0.4); }
    50%       { background-color: rgb(30 64 175 / 0.6); }
}
.segment-active       { animation: segment-pulse 2s ease-in-out infinite; }
.dark .segment-active { animation: segment-pulse-dark 2s ease-in-out infinite; }
